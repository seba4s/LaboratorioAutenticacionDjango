{
  "version": 2,
  "builds": [
    {
      "src": "evaluaciones_nombre/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "evaluaciones_nombre/wsgi.py"
    }
  ],
  "buildCommand": "python manage.py migrate && python manage.py collectstatic --noinput"
}